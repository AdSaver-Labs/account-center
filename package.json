{
  "name": "account-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "account-center": "packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b && node scripts/checkpoint.mjs build passed",
    "checkpoint": "node scripts/checkpoint.mjs checkpoint passed",
    "test": "npm run build && node --test \"packages/*/dist/**/*.test.js\" && node scripts/checkpoint.mjs test passed",
    "typecheck": "tsc -b --pretty false && node scripts/checkpoint.mjs typecheck passed"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
