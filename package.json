{
  "name": "account-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "account-center": "packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b && node scripts/checkpoint.mjs build passed",
    "checkpoint": "node scripts/checkpoint.mjs checkpoint passed",
    "test": "npm run build && node --test \"packages/*/dist/**/*.test.js\" scripts/account-center-mcp.test.mjs && node scripts/checkpoint.mjs test passed",
    "test:a11y": "npm run build && playwright test --config=playwright.a11y.config.mjs",
    "qa": "node scripts/quality-gate.mjs",
    "qa:security": "node scripts/quality-gate.mjs --security",
    "typecheck": "tsc -b --pretty false && node scripts/checkpoint.mjs typecheck passed"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.11",
    "axe-core": "^4.12.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
